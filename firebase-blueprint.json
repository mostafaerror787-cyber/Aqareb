{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A streetwear product in the catalog",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "images": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "category": { "type": "string" },
        "tag": { "type": "string" },
        "specs": {
          "type": "object",
          "properties": {
            "material": { "type": "string" },
            "fit": { "type": "string" },
            "care": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "quantity": { "type": "number" },
              "size": { "type": "string" },
              "price": { "type": "number" },
              "name": { "type": "string" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "customerInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "total", "status", "customerInfo", "createdAt"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of streetwear products"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    }
  }
}
